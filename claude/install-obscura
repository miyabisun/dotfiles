#!/usr/bin/env bash
# Obscura (headless browser) installer.
# Builds from source so it behaves identically on Manjaro / WSL(Ubuntu) / macOS
# — the only requirement is git + cargo. Obscura is not published on crates.io,
# and binary tarballs differ per OS/arch, so source build is the portable path.
# The first build compiles/fetches V8 (a few minutes); later builds are cached.
set -euo pipefail

if ! command -v cargo >/dev/null 2>&1; then
  cat <<'MSG'
Rust toolchain (cargo) is required but not found.
Install it via rustup (same command on Linux and macOS):

  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh

Then restart your shell and re-run this script.
MSG
  exit 1
fi

BUILD_DIR="$(mktemp -d)"
trap 'rm -rf "$BUILD_DIR"' EXIT

echo "==> Cloning Obscura..."
git clone --depth 1 https://github.com/h4ckf0r0day/obscura.git "$BUILD_DIR"

echo "==> Building (cargo build --release; first build compiles V8, takes minutes)..."
( cd "$BUILD_DIR" && cargo build --release )

DEST="$HOME/.local/bin"
mkdir -p "$DEST"
cp "$BUILD_DIR/target/release/obscura" "$BUILD_DIR/target/release/obscura-worker" "$DEST/"

echo "==> Installed to $DEST/obscura (+ obscura-worker)"
echo "    Make sure $DEST is on your PATH."

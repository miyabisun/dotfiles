#!/usr/bin/env bash
# Install CLI tools across Manjaro / Ubuntu(WSL) / macOS.
# Requirements: git, cargo (rustup). Run after bin/install for PATH setup.
set -euo pipefail

run_remote_installer() {
  local name="$1"
  local url="$2"
  local installer
  local status

  installer="$(mktemp)"
  if curl --proto '=https' --tlsv1.2 -fsSL "$url" -o "$installer" && bash "$installer"; then
    rm -f "$installer"
    return
  else
    status=$?
  fi

  rm -f "$installer"
  echo "==> Failed to install $name" >&2
  return "$status"
}

# ---------------------------------------------------------------------------
# Agent CLIs — official standalone installers for Linux and macOS
# ---------------------------------------------------------------------------
install_cursor() {
  if command -v cursor-agent >/dev/null 2>&1; then
    echo "==> Cursor CLI already installed ($(cursor-agent --version 2>/dev/null | head -1))"
    return
  fi

  echo "==> Installing Cursor CLI..."
  run_remote_installer "Cursor CLI" "https://cursor.com/install"
  echo "==> Cursor CLI installed"
}

install_codex() {
  if command -v codex >/dev/null 2>&1; then
    echo "==> Codex CLI already installed ($(codex --version 2>/dev/null | head -1))"
    return
  fi

  echo "==> Installing Codex CLI..."
  run_remote_installer "Codex CLI" "https://chatgpt.com/codex/install.sh"
  echo "==> Codex CLI installed"
}

install_agent_clis() {
  install_cursor
  install_codex
}

# ---------------------------------------------------------------------------
# agent-talkd — tmux agent message broker
# The repository is private, so release downloads require an authenticated gh.
# ---------------------------------------------------------------------------
install_agent_talk() (
  version="v0.1.0"
  repo="miyabi-sunny-side/agent-talkd"

  case "$(uname -s)-$(uname -m)" in
    Linux-x86_64)
      archive="agent-talk-linux-x86_64.tar.gz"
      expected_sha256="f8db795ac4e1d964e003a1e7e6f298cfd47a14175dcd5f22c653cdf55caa1ddd"
      ;;
    Darwin-arm64)
      archive="agent-talk-macos-aarch64.tar.gz"
      expected_sha256="391ba3e6b3d1578a3a8ebdb77a0df5cd6683f20591056f0e5e1fc0d87d324ea5"
      ;;
    *)
      echo "==> agent-talkd does not support $(uname -s)-$(uname -m)" >&2
      return 1
      ;;
  esac

  tmpdir="$(mktemp -d)"
  trap 'rm -rf "$tmpdir"' EXIT

  echo "==> Installing agent-talkd ${version}..."
  if ! command -v gh >/dev/null 2>&1 || ! gh auth status >/dev/null 2>&1; then
    echo "==> agent-talkd requires an authenticated GitHub CLI: gh auth login" >&2
    return 1
  fi
  gh release download "$version" --repo "$repo" \
    --pattern "$archive" --pattern "$archive.sha256" --dir "$tmpdir"

  if [ "$(uname -s)" = Darwin ]; then
    ( cd "$tmpdir" && shasum -a 256 -c "${archive}.sha256" )
    actual_sha256="$(shasum -a 256 "$tmpdir/$archive" | awk '{ print $1 }')"
  else
    ( cd "$tmpdir" && sha256sum -c "${archive}.sha256" )
    actual_sha256="$(sha256sum "$tmpdir/$archive" | awk '{ print $1 }')"
  fi
  if [ "$actual_sha256" != "$expected_sha256" ]; then
    echo "==> agent-talkd checksum does not match the pinned ${version} asset" >&2
    return 1
  fi

  tar -xzf "$tmpdir/$archive" -C "$tmpdir"
  mkdir -p "$HOME/.local/bin"
  # Retire the legacy dotfiles symlink without following it on either GNU or
  # BSD install implementations.
  if [ -L "$HOME/.local/bin/agent-talk" ]; then
    unlink "$HOME/.local/bin/agent-talk"
  fi
  install -m755 "$tmpdir/agent-talk" "$HOME/.local/bin/agent-talk"
  echo "==> agent-talkd ${version} installed"
)

# ---------------------------------------------------------------------------
# git-delta — syntax-highlighting pager for git diff/log/show
# ---------------------------------------------------------------------------
install_delta() {
  if command -v delta >/dev/null 2>&1; then
    echo "==> git-delta already installed ($(delta --version))"
    return
  fi

  echo "==> Installing git-delta..."
  if command -v pacman >/dev/null 2>&1; then
    sudo pacman -S --noconfirm git-delta
  elif command -v brew >/dev/null 2>&1; then
    brew install git-delta
  elif command -v apt-get >/dev/null 2>&1; then
    cargo install git-delta
  else
    cargo install git-delta
  fi
  echo "==> git-delta installed ($(delta --version))"
}

# ---------------------------------------------------------------------------
# rbw — Rust 製 Bitwarden CLI (bin/bw/* のバックエンド)
# 常駐 agent が鍵を保持するため公式 bw (Node) より大幅に速い
# ---------------------------------------------------------------------------
install_rbw() {
  if command -v rbw >/dev/null 2>&1; then
    echo "==> rbw already installed ($(rbw --version))"
    return
  fi

  echo "==> Installing rbw..."
  if command -v pacman >/dev/null 2>&1; then
    sudo pacman -S --noconfirm rbw
  elif command -v brew >/dev/null 2>&1; then
    brew install rbw
  else
    cargo install rbw
  fi
  echo "==> rbw installed ($(rbw --version))"
}

# ---------------------------------------------------------------------------
# Obscura — Rust headless browser with V8, used by Claude Code
# Builds from source: not on crates.io, binaries differ per OS/arch.
# First build compiles V8 (a few minutes); later builds are cached.
# ---------------------------------------------------------------------------
install_obscura() {
  if command -v obscura >/dev/null 2>&1; then
    echo "==> Obscura already installed ($HOME/.local/bin/obscura)"
    return
  fi

  if ! command -v cargo >/dev/null 2>&1; then
    cat <<'MSG'
Rust toolchain (cargo) is required but not found.
Install via rustup (Linux / macOS):

  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh

Then restart your shell and re-run this script.
MSG
    exit 1
  fi

  BUILD_DIR="$(mktemp -d)"
  trap 'rm -rf "$BUILD_DIR"' EXIT

  echo "==> Cloning Obscura..."
  git clone --depth 1 https://github.com/h4ckf0r0day/obscura.git "$BUILD_DIR"

  echo "==> Building (first build compiles V8, takes a few minutes)..."
  ( cd "$BUILD_DIR" && cargo build --release )

  DEST="$HOME/.local/bin"
  mkdir -p "$DEST"
  cp "$BUILD_DIR/target/release/obscura" "$BUILD_DIR/target/release/obscura-worker" "$DEST/"
  echo "==> Installed to $DEST/obscura (+ obscura-worker)"
  echo "    Make sure $DEST is on your PATH."
}

# ---------------------------------------------------------------------------

install_agent_clis
install_agent_talk
install_delta
install_rbw
install_obscura

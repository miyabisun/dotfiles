#!/bin/bash
# Bitwarden の "CLI" フォルダで環境変数向けの secret を管理する
source "$(dirname "${BASH_SOURCE[0]}")/lib.sh"

FOLDER="CLI"
SECRETS_FILE="$HOME/.config/.secrets"

usage() {
    cat <<'EOF'
Usage: bw-secret <command> [args]

Commands:
  save <name> <value>   secret を保存し、ローカルの ~/.config/.secrets を更新する
  load                  全 secret を ~/.config/.secrets に書き出す (export KEY="VALUE")
  list                  保存済みの secret 名を一覧する
  remove <name>         secret を削除し、ローカルの ~/.config/.secrets を更新する
EOF
    exit 1
}

write_secrets_file() {
    local fid="$1"
    echo "# Generated by bw-secret load on $(date)" > "$SECRETS_FILE"
    chmod 600 "$SECRETS_FILE"
    bw list items --folderid "$fid" \
        | jq -r '.[] | "export \(.name | gsub(" "; "_"))=\"\(.login.password)\""' >> "$SECRETS_FILE"
    echo "Secrets written to $SECRETS_FILE"
}

cmd_save() {
    local name="${1:-}" value="${2:-}"
    { [ -z "$name" ] || [ -z "$value" ]; } && usage
    local fid
    fid=$(folder_id "$FOLDER")
    delete_items_by_name "$fid" "$name"
    jq -n --arg name "$name" --arg value "$value" --arg folderId "$fid" '{
        type: 1,
        name: $name,
        folderId: $folderId,
        login: { username: null, password: $value }
    }' | create_item
    echo "Saved secret '$name'."
    bw sync > /dev/null
    write_secrets_file "$fid"
}

cmd_load() {
    write_secrets_file "$(folder_id "$FOLDER")"
}

cmd_list() {
    list_item_names "$(folder_id "$FOLDER")"
}

cmd_remove() {
    local name="${1:-}"
    [ -z "$name" ] && usage
    local fid ids
    fid=$(folder_id "$FOLDER")
    ids=$(bw list items --folderid "$fid" \
        | jq -r --arg name "$name" '.[] | select(.name == $name) | .id')
    if [ -z "$ids" ]; then
        echo "Error: secret '$name' not found." >&2
        exit 1
    fi
    delete_items_by_name "$fid" "$name"
    echo "Removed secret '$name'."
    bw sync > /dev/null
    write_secrets_file "$fid"
}

case "${1:-}" in
    save|load|list|remove)
        cmd="$1"; shift
        require_unlocked
        "cmd_$cmd" "$@"
        ;;
    *) usage ;;
esac

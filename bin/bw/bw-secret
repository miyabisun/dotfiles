#!/bin/bash
# Bitwarden の "CLI" フォルダで環境変数向けの secret を管理する
source "$(dirname "${BASH_SOURCE[0]}")/lib.sh"

FOLDER="CLI"
SECRETS_FILE="$HOME/.config/.secrets"

usage() {
    cat <<'EOF'
Usage: bw-secret <command> [args]

Commands:
  save <name> <value>   secret を保存し、ローカルの ~/.config/.secrets を更新する
  load                  全 secret を ~/.config/.secrets に書き出す (export KEY=VALUE)
  get <name>            secret の値を stdout に出す
  list                  保存済みの secret 名を一覧する
  remove <name>         secret を削除し、ローカルの ~/.config/.secrets を更新する
EOF
    exit 1
}

write_secrets_file() {
    local name value
    {
        echo "# Generated by bw-secret load on $(date)"
        list_item_names "$FOLDER" | while read -r name; do
            value=$(rbw get --folder "$FOLDER" "$name" --field password)
            printf 'export %s=%q\n' "${name// /_}" "$value"
        done
    } > "$SECRETS_FILE"
    chmod 600 "$SECRETS_FILE"
    echo "Secrets written to $SECRETS_FILE"
}

cmd_save() {
    local name="${1:-}" value="${2:-}"
    { [ -z "$name" ] || [ -z "$value" ]; } && usage
    delete_items_by_name "$FOLDER" "$name"
    printf '%s\n' "$value" | rbw_add_item "$FOLDER" "$name"
    echo "Saved secret '$name'."
    write_secrets_file
}

cmd_load() {
    write_secrets_file
}

cmd_get() {
    local name="${1:-}"
    [ -z "$name" ] && usage
    rbw get --folder "$FOLDER" "$name" --field password
}

cmd_list() {
    list_item_names "$FOLDER"
}

cmd_remove() {
    local name="${1:-}"
    [ -z "$name" ] && usage
    get_item_raw "$FOLDER" "$name" > /dev/null
    delete_items_by_name "$FOLDER" "$name"
    echo "Removed secret '$name'."
    write_secrets_file
}

case "${1:-}" in
    save|load|get|list|remove)
        cmd="$1"; shift
        require_unlocked
        "cmd_$cmd" "$@"
        ;;
    *) usage ;;
esac

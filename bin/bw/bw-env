#!/bin/bash
# Bitwarden の "Env Files" フォルダでプロジェクトの .env ファイルを管理する
# (.env は '#' コメントを含み得るため base64 で notes に保存する)
source "$(dirname "${BASH_SOURCE[0]}")/lib.sh"

FOLDER="Env Files"

usage() {
    cat <<'EOF'
Usage: bw-env <command> [args]

Commands:
  save <name> [file]   .env ファイルを保存する (default: ./.env)
  load <name> [file]   .env ファイルを復元する (default: ./.env, 0600)
  get <name> <var>     保存した .env から1変数の値だけを stdout に出す
  keys <name>          保存した .env の変数名一覧を stdout に出す
  list                 保存済みの .env 一覧
  remove <name>        保存した .env を削除する

name にはプロジェクト名を使う (例: bw-env save shoebox ~/projects/shoebox/.env)
EOF
    exit 1
}

get_content() { # <name>
    get_item_notes "$FOLDER" "$1" | base64 -d
}

cmd_save() {
    local name="${1:-}" file="${2:-./.env}"
    [ -z "$name" ] && usage
    if [ ! -f "$file" ]; then
        echo "Error: env file not found at $file" >&2
        exit 1
    fi
    delete_items_by_name "$FOLDER" "$name"
    { echo "-"; echo; base64 < "$file"; } | rbw_add_item "$FOLDER" "$name"
    echo "Saved '$name' to '$FOLDER' folder."
}

cmd_load() {
    local name="${1:-}" file="${2:-./.env}"
    [ -z "$name" ] && usage
    get_content "$name" > "$file"
    chmod 600 "$file"
    echo "Saved env file to $file"
}

cmd_get() {
    local name="${1:-}" var="${2:-}" value
    { [ -z "$name" ] || [ -z "$var" ]; } && usage
    value=$(get_content "$name" | sed -n "s/^${var}=//p" | head -n 1)
    if [ -z "$value" ]; then
        echo "Error: variable '$var' not found in env '$name'." >&2
        exit 1
    fi
    printf '%s\n' "$value"
}

cmd_keys() {
    local name="${1:-}"
    [ -z "$name" ] && usage
    get_content "$name" | sed -n 's/^\([A-Za-z_][A-Za-z0-9_]*\)=.*/\1/p'
}

cmd_list() {
    list_item_names "$FOLDER"
}

cmd_remove() {
    local name="${1:-}"
    [ -z "$name" ] && usage
    get_item_raw "$FOLDER" "$name" > /dev/null
    delete_items_by_name "$FOLDER" "$name"
    echo "Removed '$name'."
}

case "${1:-}" in
    save|load|get|keys|list|remove)
        cmd="$1"; shift
        require_unlocked
        "cmd_$cmd" "$@"
        ;;
    *) usage ;;
esac

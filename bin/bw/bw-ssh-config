#!/bin/bash
# Bitwarden の "SSH Config" フォルダで ~/.ssh/conf.d/*.conf を管理する
source "$(dirname "${BASH_SOURCE[0]}")/lib.sh"

FOLDER="SSH Config"
CONF_DIR="$HOME/.ssh/conf.d"

usage() {
    cat <<'EOF'
Usage: bw-ssh-config <command> [args]

Commands:
  save [name]    ~/.ssh/conf.d/<name>.conf を保存 (name 省略時は fzf で選択)
  load           全 config を ~/.ssh/conf.d/ に復元する
  list           保存済みの config 名を一覧する
  remove <name>  保存した config を削除する
EOF
    exit 1
}

cmd_save() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        require_deps fzf
        name=$(find "$CONF_DIR" -maxdepth 1 -name "*.conf" -printf "%f\n" | sed 's/\.conf$//' | fzf)
        [ -z "$name" ] && { echo "No file selected. Exiting."; exit 0; }
    fi
    local config_file="$CONF_DIR/${name}.conf"
    if [ ! -f "$config_file" ]; then
        echo "Error: config file not found at $config_file" >&2
        exit 1
    fi

    local uri="" user="" fields="[]" line key value filename
    while read -r line; do
        line=$(echo "$line" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
        { [ -z "$line" ] || [[ "$line" == \#* ]]; } && continue
        key=$(echo "$line" | awk '{print $1}')
        value=$(echo "$line" | awk '{$1=""; print $0}' | sed -e 's/^[[:space:]]*//')
        case "$key" in
            Host) ;;  # Host 行は item 名から復元するので保存しない
            HostName) uri="$value" ;;
            User) user="$value" ;;
            IdentityFile)
                filename=$(basename "$value")
                fields=$(echo "$fields" | jq --arg name "$key" --arg value "$filename" \
                    '. + [{name: $name, value: $value, type: 0}]')
                ;;
            *)
                fields=$(echo "$fields" | jq --arg name "$key" --arg value "$value" \
                    '. + [{name: $name, value: $value, type: 0}]')
                ;;
        esac
    done < "$config_file"

    local fid
    fid=$(folder_id "$FOLDER")
    delete_items_by_name "$fid" "$name"
    jq -n \
        --arg name "$name" \
        --arg folderId "$fid" \
        --arg username "$user" \
        --arg uri "$uri" \
        --argjson fields "$fields" \
        '{
            type: 1,
            name: $name,
            folderId: $folderId,
            login: {
                username: $username,
                uris: (if $uri != "" then [{match: null, uri: $uri}] else [] end)
            },
            fields: $fields
        }' | create_item
    echo "Saved '$name' to '$FOLDER' folder."
}

cmd_load() {
    mkdir -p "$CONF_DIR"
    bw list items --folderid "$(folder_id "$FOLDER")" | jq -c '.[]' | while read -r item; do
        local name uri user config_file field field_name field_value
        name=$(echo "$item" | jq -r '.name')
        uri=$(echo "$item" | jq -r '.login.uris[0].uri // empty')
        user=$(echo "$item" | jq -r '.login.username // empty')
        config_file="$CONF_DIR/${name}.conf"
        echo "Restoring config for '$name'..."
        {
            echo "# Generated by bw-ssh-config load on $(date)"
            echo "Host $name"
            [ -n "$uri" ] && echo "  HostName $uri"
            [ -n "$user" ] && echo "  User $user"
        } > "$config_file"
        echo "$item" | jq -c '.fields[]?' | while read -r field; do
            field_name=$(echo "$field" | jq -r '.name')
            field_value=$(echo "$field" | jq -r '.value')
            if [ "$field_name" = "IdentityFile" ]; then
                echo "  $field_name ~/.ssh/$field_value" >> "$config_file"
            else
                echo "  $field_name $field_value" >> "$config_file"
            fi
        done
        echo "  Saved to $config_file"
    done
    echo "Done."
}

cmd_list() {
    list_item_names "$(folder_id "$FOLDER")"
}

cmd_remove() {
    local name="${1:-}"
    [ -z "$name" ] && usage
    local fid
    fid=$(folder_id "$FOLDER")
    find_item "$fid" "$name" > /dev/null
    delete_items_by_name "$fid" "$name"
    echo "Removed '$name'."
}

case "${1:-}" in
    save|load|list|remove)
        cmd="$1"; shift
        require_unlocked
        "cmd_$cmd" "$@"
        ;;
    *) usage ;;
esac

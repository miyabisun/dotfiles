#!/bin/bash
# Bitwarden の "SSH Config" フォルダで ~/.ssh/conf.d/*.conf を管理する
# (.conf は '#' コメントを含み得るため base64 で notes にそのまま保存する)
source "$(dirname "${BASH_SOURCE[0]}")/lib.sh"

FOLDER="SSH Config"
CONF_DIR="$HOME/.ssh/conf.d"

usage() {
    cat <<'EOF'
Usage: bw-ssh-config <command> [args]

Commands:
  save [name]    ~/.ssh/conf.d/<name>.conf を保存 (name 省略時は fzf で選択)
  load           全 config を ~/.ssh/conf.d/ に復元する
  cat <name>     保存した config を stdout に出す
  list           保存済みの config 名を一覧する
  remove <name>  保存した config を削除する
EOF
    exit 1
}

cmd_save() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        require_deps fzf
        name=$(find "$CONF_DIR" -maxdepth 1 -name "*.conf" -printf "%f\n" | sed 's/\.conf$//' | fzf)
        [ -z "$name" ] && { echo "No file selected. Exiting."; exit 0; }
    fi
    local config_file="$CONF_DIR/${name}.conf"
    if [ ! -f "$config_file" ]; then
        echo "Error: config file not found at $config_file" >&2
        exit 1
    fi
    delete_items_by_name "$FOLDER" "$name"
    { echo "-"; echo; base64 < "$config_file"; } | rbw_add_item "$FOLDER" "$name"
    echo "Saved '$name' to '$FOLDER' folder."
}

cmd_load() {
    local name config_file
    mkdir -p "$CONF_DIR"
    list_item_names "$FOLDER" | while read -r name; do
        config_file="$CONF_DIR/${name}.conf"
        get_item_notes "$FOLDER" "$name" | base64 -d > "$config_file"
        chmod 600 "$config_file"
        echo "Restored $config_file"
    done
    echo "Done."
}

cmd_cat() {
    local name="${1:-}"
    [ -z "$name" ] && usage
    get_item_notes "$FOLDER" "$name" | base64 -d
}

cmd_list() {
    list_item_names "$FOLDER"
}

cmd_remove() {
    local name="${1:-}"
    [ -z "$name" ] && usage
    get_item_raw "$FOLDER" "$name" > /dev/null
    delete_items_by_name "$FOLDER" "$name"
    echo "Removed '$name'."
}

case "${1:-}" in
    save|load|cat|list|remove)
        cmd="$1"; shift
        require_unlocked
        "cmd_$cmd" "$@"
        ;;
    *) usage ;;
esac

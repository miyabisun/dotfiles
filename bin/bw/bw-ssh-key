#!/bin/bash
# Bitwarden の "SSH Keys" フォルダで SSH 鍵ペアを管理する
# (password = 公開鍵 1行, notes = 秘密鍵 PEM)
source "$(dirname "${BASH_SOURCE[0]}")/lib.sh"

FOLDER="SSH Keys"

usage() {
    cat <<'EOF'
Usage: bw-ssh-key <command> [args]

Commands:
  save [name] [filename]   ~/.ssh/<filename> の鍵ペアを保存 (default: default id_rsa)
  load [name] [filename]   鍵ペアを ~/.ssh/<filename>(.pub) に復元
  cat [name]               鍵ペアを stdout に出す (1行目: 公開鍵, 以降: 秘密鍵)
  list                     保存済みの鍵名を一覧する
  remove <name>            保存した鍵を削除する
EOF
    exit 1
}

cmd_save() {
    local name="${1:-default}" filename="${2:-id_rsa}"
    local private_path="$HOME/.ssh/$filename" public_path="$HOME/.ssh/$filename.pub"
    for f in "$private_path" "$public_path"; do
        if [ ! -f "$f" ]; then
            echo "Error: key file not found at $f" >&2
            exit 1
        fi
    done
    delete_items_by_name "$FOLDER" "$name"
    { head -n 1 "$public_path"; echo; cat "$private_path"; } \
        | rbw_add_item "$FOLDER" "$name"
    echo "Saved '$name' to '$FOLDER' folder."
}

cmd_load() {
    local name="${1:-default}" filename="${2:-id_rsa}"
    local private_path="$HOME/.ssh/$filename" public_path="$HOME/.ssh/$filename.pub"
    local item private public
    item=$(get_item_raw "$FOLDER" "$name")
    private=$(echo "$item" | jq -r '.notes // empty')
    public=$(echo "$item" | jq -r '.data.password // empty')
    if [ -z "$private" ]; then
        echo "Error: private key not found in item '$name'." >&2
        exit 1
    fi
    mkdir -p "$HOME/.ssh"
    chmod 700 "$HOME/.ssh"
    printf '%s\n' "$private" > "$private_path"
    chmod 600 "$private_path"
    echo "Saved private key to $private_path"
    if [ -n "$public" ]; then
        printf '%s\n' "$public" > "$public_path"
        chmod 644 "$public_path"
        echo "Saved public key to $public_path"
    fi
}

cmd_cat() {
    local name="${1:-default}" item
    item=$(get_item_raw "$FOLDER" "$name")
    jq -r '.data.password // empty' <<< "$item"
    echo
    jq -r '.notes // empty' <<< "$item"
}

cmd_list() {
    list_item_names "$FOLDER"
}

cmd_remove() {
    local name="${1:-}"
    [ -z "$name" ] && usage
    get_item_raw "$FOLDER" "$name" > /dev/null
    delete_items_by_name "$FOLDER" "$name"
    echo "Removed '$name'."
}

case "${1:-}" in
    save|load|cat|list|remove)
        cmd="$1"; shift
        require_unlocked
        "cmd_$cmd" "$@"
        ;;
    *) usage ;;
esac

#!/bin/bash
# Bitwarden の "Age Keys" フォルダで age の鍵 (identity/recipient) を管理する
# (password = recipient, notes = AGE-SECRET-KEY 行。'#' コメント行は保存しない)
source "$(dirname "${BASH_SOURCE[0]}")/lib.sh"

FOLDER="Age Keys"
DEFAULT_KEY_FILE="$HOME/.config/age/keys.txt"

usage() {
    cat <<'EOF'
Usage: bw-age <command> [args]

Commands:
  create [name]       age-keygen で鍵を生成して保存する (ディスクには残さない)
  save [name] [file]  既存の identity ファイルを保存 (default: ~/.config/age/keys.txt)
  identity [name]     秘密鍵 (identity) を stdout に出す (ディスクに書かない)
  recipient [name]    公開鍵 (age1...) を表示する
  list                保存済みの鍵名を一覧する
  remove <name>       保存した鍵を削除する

name の default は "default"
EOF
    exit 1
}

save_identity() { # <name> <identity_text> <recipient>
    delete_items_by_name "$FOLDER" "$1"
    { printf '%s\n\n' "$3"; printf '%s\n' "$2" | grep -v '^#'; } \
        | rbw_add_item "$FOLDER" "$1"
    echo "Saved '$1' to '$FOLDER' folder."
    printf '%s\n' "$3"
}

cmd_create() {
    require_deps age-keygen
    local name="${1:-default}" identity recipient
    identity=$(age-keygen 2> /dev/null)
    recipient=$(echo "$identity" | sed -n 's/^# public key: //p')
    save_identity "$name" "$identity" "$recipient"
}

cmd_save() {
    require_deps age-keygen
    local name="${1:-default}" file="${2:-$DEFAULT_KEY_FILE}" recipient
    if [ ! -f "$file" ]; then
        echo "Error: identity file not found at $file" >&2
        exit 1
    fi
    recipient=$(age-keygen -y "$file")
    save_identity "$name" "$(cat "$file")" "$recipient"
}

cmd_identity() {
    get_item_notes "$FOLDER" "${1:-default}"
}

cmd_recipient() {
    rbw get --folder "$FOLDER" "${1:-default}" --field password
}

cmd_list() {
    list_item_names "$FOLDER"
}

cmd_remove() {
    local name="${1:-}"
    [ -z "$name" ] && usage
    get_item_raw "$FOLDER" "$name" > /dev/null
    delete_items_by_name "$FOLDER" "$name"
    echo "Removed '$name'."
}

case "${1:-}" in
    create|save|identity|recipient|list|remove)
        cmd="$1"; shift
        require_unlocked
        "cmd_$cmd" "$@"
        ;;
    *) usage ;;
esac

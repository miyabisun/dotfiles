#!/bin/bash
script_dir="$(cd "$(dirname "${BASH_SOURCE:-${(%):-%N}}")"; pwd)"
cd "$script_dir/../"

function link () {
  from="$(pwd)/$1"
  to="${2:-$HOME}"
  ln -sfv "$from" "$to"
}

link ".editorconfig"


mkdir -p "$HOME/.ssh/conf.d"
link "ssh/config" "$HOME/.ssh"

mkdir -p "$HOME/.config"
link "config/git" "$HOME/.config"
link "config/nvim" "$HOME/.config"
link "config/tmux" "$HOME/.config"
link "config/.deepl.json" "$HOME/.config"

mkdir -p "$HOME/.claude"
link "agent/common/skills" "$HOME/.claude"
link "agent/common/agents" "$HOME/.claude"
link "agent/common/designs" "$HOME/.claude"
link "agent/claude/hooks" "$HOME/.claude"
link "agent/claude/CLAUDE.md" "$HOME/.claude"
link "agent/claude/settings.json" "$HOME/.claude"

mkdir -p "$HOME/.cursor"
link "agent/common/skills" "$HOME/.cursor"
link "agent/common/agents" "$HOME/.cursor"
link "agent/common/designs" "$HOME/.cursor"
link "agent/cursor/rules" "$HOME/.cursor"
link "agent/cursor/hooks" "$HOME/.cursor"
ln -sfv "$(pwd)/agent/cursor/hooks.json" "$HOME/.cursor/hooks.json"

mkdir -p "$HOME/.codex"
link "agent/codex/config.toml" "$HOME/.codex"
link "agent/codex/hooks.json" "$HOME/.codex"
link "agent/codex/agents" "$HOME/.codex"
link "agent/common/rules/GLOBAL.md" "$HOME/.codex/AGENTS.md"

mkdir -p "$HOME/.agents"
link "agent/common/skills" "$HOME/.agents"
link "agent/common/agents" "$HOME/.agents"
link "agent/common/designs" "$HOME/.agents"

mkdir -p "$HOME/.local/bin"
link "agent/common/bin/emit-turn-end.sh" "$HOME/.local/bin"
link "config/tmux/bin/tmux-session-picker" "$HOME/.local/bin"

mkdir -p "$HOME/.config/sheldon"
link "config/zsh/plugins.toml" "$HOME/.config/sheldon"
command -v sheldon > /dev/null && sheldon lock

START_MARK="# DOTFILES_START"
END_MARK="# DOTFILES_END"

EXPORTS_LINE='[ -f "$HOME/.dotfiles/config/bash/exports.sh" ] && . "$HOME/.dotfiles/config/bash/exports.sh"'
ZSH_LINE='[ -f "$HOME/.dotfiles/config/zsh/init.zsh" ] && . "$HOME/.dotfiles/config/zsh/init.zsh"'

for rcfile in "$HOME/.bashrc" "$HOME/.zshrc"; do
  if [ -f "$rcfile" ]; then
    if ! grep -q "$START_MARK" "$rcfile"; then
      echo "Adding dotfiles config to $rcfile..."
      {
        echo ""
        echo "$START_MARK"
        echo "$EXPORTS_LINE"
        if [ "$rcfile" = "$HOME/.zshrc" ]; then
          echo "$ZSH_LINE"
        fi
        echo "$END_MARK"
      } >> "$rcfile"
    else
      echo "Dotfiles config already present in $rcfile."
    fi
  fi
done

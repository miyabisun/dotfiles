#!/usr/bin/env bash
set -euo pipefail

# agent-talk: tmux 上の対話エージェント (claude / codex など) 同士の連絡係。
#
# 登録と busy/idle は tmux の pane オプション (@agent / @agent_state) で持ち、
# 両エージェントの UserPromptSubmit / ターン終了フックが権威的に更新する。
# 依頼の本文はファイルで渡し、send-keys は呼び鈴に徹する。
# busy な宛先には send-keys しない (Codex は作業中の Enter 入力を現在ターンへの
# steer として扱うため)。呼び鈴はキューに積み、宛先自身のターン終了フック
# (emit-turn-end.sh → agent-talk turn-end) がアイドルになった瞬間に配達する。
#
# 配達はすべて dispatch 一本に集約する: pane 単位の flock 内で登録を再検証し、
# idle なら即配達 / busy なら退避 / 配達失敗なら idle 復旧の上キューへ保全。
# 配達不能 (宛先退出) のキューは送信元へ「配達失敗」通知として返送する。
#
#   agent-talk register <name>    自 pane を <name> として待受登録 (state=idle)。
#                                 前住人の残留キューは送信元へ失敗通知して破棄
#   agent-talk unregister         待受登録を解除。未配達キューは送信元へ失敗通知
#   agent-talk busy | idle        自 pane の状態を更新 (フック用)
#   agent-talk turn-end           ターン終了処理: idle 化 + キュー最古の1通を配達
#   agent-talk who                待受中エージェントの一覧 (状態つき、読み取り専用)
#   agent-talk gc                 宛先不在キューの回収と送信元への失敗通知
#   agent-talk resolve <addr>     <addr> を pane ID に解決 (曖昧なら候補を出して失敗)
#   agent-talk send <addr> [msg]  依頼書ファイルを書き、宛先が idle なら呼び鈴、
#                                 busy ならキューに退避 (msg 省略時は stdin が本文)
#
# <addr> は <name>、<scope>/<name>、または返信用の %<pane-id>。
# scope は tmux セッション名か pane のカレントディレクトリ名
# (プロジェクト名) に一致する。
# scope なしの解決は同じ window → 同じ session の順で探し、session は跨がない。

MAILDIR="${AGENT_TALK_DIR:-$HOME/.cache/agent-talk}"
QUEUEDIR="$MAILDIR/queue"
WATCH_INTERVAL="${AGENT_TALK_WATCH_INTERVAL:-30}"
[[ "$WATCH_INTERVAL" =~ ^[1-9][0-9]*$ ]] || WATCH_INTERVAL=30
FMT=$'#{session_name}\t#{window_id}\t#{pane_id}\t#{pane_current_path}\t#{@agent}\t#{window_index}\t#{pane_index}\t#{@agent_state}'

die() { echo "agent-talk: $*" >&2; exit 1; }

# ---- pane 単位ロック ---------------------------------------------------------
# flock の FD ロックを使う。プロセス死亡でカーネルが必ず解放するため
# stale lock も奪取判断も存在しない。ロックファイル自体は残るが無害

LOCK_FD=""

lock_pane() {
  local pane="$1"
  command -v flock > /dev/null 2>&1 || die "flock が必要です (util-linux)"
  umask 077
  mkdir -p -- "$QUEUEDIR"
  exec {LOCK_FD}> "$QUEUEDIR/.lock-$pane"
  flock -w 10 "$LOCK_FD" || die "pane $pane のロックを取得できません"
}

release_lock() {
  [[ -n "$LOCK_FD" ]] && exec {LOCK_FD}>&-
  LOCK_FD=""
}

# ---- 基本情報 ---------------------------------------------------------------

# tmux 不達 (サンドボックス等) と登録ゼロを区別する。前者を空リストに
# 変換すると「誰も居ない」という嘘になるので、正直に失敗させる。
list_agents() {
  local out
  out="$(tmux list-panes -a -F "$FMT" 2>&1)" \
    || die "tmux サーバーに接続できません (sandbox 内なら承認付きで再実行): ${out}"
  awk -F'\t' '$5 != ""' <<< "$out"
}

pretty() {
  awk -F'\t' '{ printf "%-10s %-5s %s:%s.%s (%s)  %s\n", $5, ($8 == "" ? "-" : $8), $1, $6, $7, $3, $4 }'
}

pane_agent() {
  tmux show-options -pqv -t "$1" @agent 2>/dev/null || true
}

# 宛先が busy か。フックが維持する pane オプションが権威。
# オプション未設定 (登録前・移行期) の pane に限り、画面の作業中サイン
# ("esc to interrupt") を保守的フォールバックとして見る
is_busy() {
  local pane="$1" state screen
  state="$(tmux show-options -pqv -t "$pane" @agent_state 2>/dev/null || true)"
  case "$state" in
    busy) return 0 ;;
    idle) return 1 ;;
  esac
  screen="$(tmux capture-pane -p -t "$pane" 2>/dev/null || true)"
  grep -qi 'esc to interrupt' <<< "$screen"
}

# ---- キューと配達 -----------------------------------------------------------
# エントリ形式: 1行目 sender=<pane|system|human>、2行目 brief=<依頼書path>、
# 3行目以降 呼び鈴

# キューへの書き込み。dispatch は `|| rc=$?` の条件文脈から呼ばれ errexit が
# 効かないため、各 I/O を明示検査して失敗を伝搬する (偽の queued 成功の防止)
enqueue_msg() {
  local pane="$1" sender="$2" brief="$3" bell="$4"
  local qdir="$QUEUEDIR/$pane" tmp
  umask 077
  mkdir -p -- "$qdir" || return 1
  tmp="$(mktemp "$qdir/.tmp-XXXXXX")" || return 1
  if ! printf 'sender=%s\nbrief=%s\n%s\n' "$sender" "$brief" "$bell" > "$tmp"; then
    rm -f -- "$tmp"
    return 1
  fi
  mv -- "$tmp" "$qdir/$(date +%s%N)-$$.msg" || { rm -f -- "$tmp"; return 1; }
  start_watcher "$pane"
  return 0
}

# キューが生まれた pane ごとに監視プロセスを1つ起動する。宛先がフックを
# 通らず消滅 (crash / pane kill) した場合の独立した wake-up source で、
# 「どれかのエージェントが次のターンを終えるまで GC が走らない」を防ぐ
start_watcher() {
  local pane="$1" pidfile="$QUEUEDIR/.watch-${pane}.pid" pid
  # PID 再利用による誤認を避けるため、生存確認は cmdline も照合する
  pid="$(cat "$pidfile" 2>/dev/null || true)"
  if [[ -n "$pid" && -d "/proc/$pid" ]] \
    && tr '\0' ' ' < "/proc/$pid/cmdline" 2>/dev/null | grep -q 'agent-talk watch'; then
    return 0
  fi
  # 呼び出し元はロック保持中。flock は FD 相続でも維持されるため、
  # 子に LOCK_FD を渡すとロックが watcher の寿命まで解放されなくなる。
  # spawn 時に必ず閉じる
  if [[ -n "$LOCK_FD" ]]; then
    setsid "$0" watch "$pane" < /dev/null > /dev/null 2>&1 {LOCK_FD}>&- &
  else
    setsid "$0" watch "$pane" < /dev/null > /dev/null 2>&1 &
  fi
  echo $! > "$pidfile" 2>/dev/null || true
}

# watcher 本体: キューが空になるまで宛先の生存と登録を見張り、
# 消えていたら gc (失敗通知) を起動する。上限 24 時間で自然消滅
cmd_watch() {
  local pane="${1:-}" i
  [[ -n "$pane" ]] || exit 0
  for (( i = 0; i < 86400 / WATCH_INTERVAL; i++ )); do
    sleep "$WATCH_INTERVAL"
    ls "$QUEUEDIR/$pane"/*.msg > /dev/null 2>&1 || exit 0
    if ! tmux display-message -p -t "$pane" '' > /dev/null 2>&1 \
      || [[ -z "$(pane_agent "$pane")" ]]; then
      "$0" gc
      exit 0
    fi
  done
}

# 呼び鈴を pane へ注入する。呼び出し側がその pane のロックを保持していること。
# 失敗時は state を idle に戻して 1 を返す (busy 固着の防止)。
# Enter だけ失敗した場合は入力欄にテキストが残るが、再配達される呼び鈴は
# 同内容の指示なので重複しても実害はない
deliver_bell() {
  local pane="$1" bell="$2"
  tmux set-option -p -t "$pane" @agent_state busy 2>/dev/null || true
  if tmux send-keys -t "$pane" -l "$bell" 2>/dev/null; then
    sleep 0.3
    if tmux send-keys -t "$pane" Enter 2>/dev/null; then
      return 0
    fi
  fi
  tmux set-option -p -t "$pane" @agent_state idle 2>/dev/null || true
  return 1
}

# 唯一の配達入口。呼び出し側はロックを持たないこと。
# 戻り値: 0=即配達 1=キュー退避 (失敗時保全含む) 2=宛先不在 (登録なし/不一致)
#         3=キュー書き込み不能 (fatal: メッセージは永続化されていない)
dispatch() {
  local pane="$1" sender="$2" brief="$3" bell="$4" expect="${5:-}"
  lock_pane "$pane"
  local agent
  agent="$(pane_agent "$pane")"
  if [[ -z "$agent" || ( -n "$expect" && "$agent" != "$expect" ) ]]; then
    release_lock
    return 2
  fi
  if is_busy "$pane"; then
    if enqueue_msg "$pane" "$sender" "$brief" "$bell"; then
      release_lock
      return 1
    fi
    release_lock
    return 3
  fi
  if deliver_bell "$pane" "$bell"; then
    release_lock
    return 0
  fi
  if enqueue_msg "$pane" "$sender" "$brief" "$bell"; then
    release_lock
    return 1
  fi
  release_lock
  return 3
}

# 対象 pane のキューを (ロック内で) 排他的に切り離し、退避先 dir を出力する。
# キューが空なら何も出力しない。呼び出し側がロックを保持していること
detach_queue_locked() {
  local pane="$1"
  local qdir="$QUEUEDIR/$pane" drain
  [[ -d "$qdir" ]] || return 0
  # 切り離しに失敗したらキューをその場に温存する (watcher/gc が後で再試行する)。
  # 何も出力しなければ呼び出し側の notify_failures は no-op になる
  if ! drain="$(mktemp -d "$QUEUEDIR/.drain-XXXXXX")"; then
    echo "agent-talk: drain 領域を作れないためキューを温存します ($qdir)" >&2
    return 0
  fi
  if ! mv -- "$qdir" "$drain/q"; then
    rmdir "$drain" 2>/dev/null || true
    echo "agent-talk: キューを切り離せないため温存します ($qdir)" >&2
    return 0
  fi
  echo "$drain"
}

# 切り離したキューの各エントリを送信元へ「配達失敗」として返送する。
# ロック非保持で呼ぶこと (dispatch が送信元ロックを取るため)。
# 通知の sender は system なので、通知自体が不達でも再帰しない
notify_failures() {
  local drain="$1" reason="$2" f sender brief rc leftover=0
  [[ -n "$drain" && -d "$drain/q" ]] || { [[ -n "$drain" ]] && rmdir "$drain" 2>/dev/null; return 0; }
  for f in "$drain/q"/*.msg; do
    [[ -f "$f" ]] || continue
    sender="$(sed -n '1s/^sender=//p' "$f")"
    brief="$(sed -n '2s/^brief=//p' "$f")"
    if [[ ! "$sender" =~ ^%[0-9]+$ ]]; then
      rm -f -- "$f"  # human/system 発は通知先がない
      continue
    fi
    rc=0
    dispatch "$sender" "system" "$brief" \
      "[agent-talk] 配達失敗: ${brief} は ${reason} ため配達されませんでした。必要なら宛先を確認して送り直してください。" \
      || rc=$?
    # 元エントリは、通知が配達されたか永続化されたか、送信元自体が不在の
    # 場合にだけ消す。通知を書き込めなかった (rc=3) なら唯一の記録として残す
    if [[ "$rc" -le 2 ]]; then
      rm -f -- "$f"
    else
      leftover=1
    fi
  done
  if (( leftover )); then
    echo "agent-talk: 配達失敗通知を書き込めなかったため ${drain}/q に元依頼を残しました" >&2
  else
    rm -rf -- "$drain/q" 2>/dev/null || true
    rmdir "$drain" 2>/dev/null || true
  fi
}

# ---- サブコマンド -----------------------------------------------------------

cmd_register() {
  [[ -n "${TMUX:-}" && -n "${TMUX_PANE:-}" ]] || exit 0
  local name="${1:-}"
  [[ -n "$name" ]] || die "usage: agent-talk register <name>"
  [[ "$name" =~ ^[A-Za-z0-9_-]+$ ]] || die "name は英数字と - _ のみ: '$name'"
  local drain
  lock_pane "$TMUX_PANE"
  # 前住人の残留キューを暗黙配送しない
  drain="$(detach_queue_locked "$TMUX_PANE")"
  tmux set-option -p -t "$TMUX_PANE" @agent "$name"
  tmux set-option -p -t "$TMUX_PANE" @agent_state idle
  release_lock
  notify_failures "$drain" "宛先エージェントが入れ替わった"
}

cmd_unregister() {
  [[ -n "${TMUX:-}" && -n "${TMUX_PANE:-}" ]] || exit 0
  local drain
  lock_pane "$TMUX_PANE"
  tmux set-option -p -t "$TMUX_PANE" -u @agent 2>/dev/null || true
  tmux set-option -p -t "$TMUX_PANE" -u @agent_state 2>/dev/null || true
  drain="$(detach_queue_locked "$TMUX_PANE")"
  release_lock
  notify_failures "$drain" "宛先エージェントが退出した"
}

# busy/idle もロック下で更新する。dispatch の「idle 確認 → 配達」と
# 直列化しないと、確認直後の busy 化と交錯して steer し得るため。
# なお「人間がキーを打った瞬間〜フック実行まで」の窓はこの層では消せない
# (真の busy 開始はキー入力であり、フックはその後追いのため)
cmd_busy() {
  [[ -n "${TMUX:-}" && -n "${TMUX_PANE:-}" ]] || exit 0
  lock_pane "$TMUX_PANE"
  tmux set-option -p -t "$TMUX_PANE" @agent_state busy 2>/dev/null || true
  release_lock
}

cmd_idle() {
  [[ -n "${TMUX:-}" && -n "${TMUX_PANE:-}" ]] || exit 0
  lock_pane "$TMUX_PANE"
  tmux set-option -p -t "$TMUX_PANE" @agent_state idle 2>/dev/null || true
  release_lock
}

# ターン終了フックから呼ばれる: idle 化し、自分宛キューの最古の1通を配達する。
# 配達は必ず「アイドルになった本人のフック」が行うため steer が起きない。
# 1通ずつなのは、配達がすぐ次のターンを開始する (=busy に戻る) ため。
# 配達失敗時は deliver_bell が idle へ戻し、エントリはキューに残す
cmd_turn_end() {
  [[ -n "${TMUX:-}" && -n "${TMUX_PANE:-}" ]] || exit 0
  lock_pane "$TMUX_PANE"
  tmux set-option -p -t "$TMUX_PANE" @agent_state idle 2>/dev/null || true
  local qdir="$QUEUEDIR/$TMUX_PANE" oldest bell
  oldest="$(ls "$qdir" 2>/dev/null | head -1 || true)"
  if [[ -n "$oldest" ]]; then
    bell="$(tail -n +3 "$qdir/$oldest")"
    if deliver_bell "$TMUX_PANE" "$bell"; then
      rm -f -- "$qdir/$oldest"
    fi
  fi
  release_lock
}

cmd_who() {
  list_agents | pretty
}

# 宛先不在 (pane 消滅または未登録) のキューを回収し、送信元へ失敗通知する
cmd_gc() {
  [[ -d "$QUEUEDIR" ]] || exit 0
  local q pane drain
  for q in "$QUEUEDIR"/*; do
    [[ -d "$q" ]] || continue
    pane="$(basename "$q")"
    [[ "$pane" =~ ^%[0-9]+$ ]] || continue
    lock_pane "$pane"
    if tmux display-message -p -t "$pane" '' > /dev/null 2>&1 && [[ -n "$(pane_agent "$pane")" ]]; then
      release_lock
      continue
    fi
    drain="$(detach_queue_locked "$pane")"
    release_lock
    notify_failures "$drain" "宛先 ${pane} が不在の"
  done
}

cmd_resolve() {
  local addr="${1:-}"
  [[ -n "$addr" ]] || die "usage: agent-talk resolve [scope/]<name> | %pane"

  # pane ID 直指定 (返信用)。@agent 登録済みの pane に限る
  if [[ "$addr" =~ ^%[0-9]+$ ]]; then
    local hit
    hit="$(list_agents | awk -F'\t' -v p="$addr" '$3 == p')"
    [[ -n "$hit" ]] || die "pane ${addr} は @agent 登録されていません"
    echo "$addr"
    return
  fi

  local scope="" name="$addr"
  if [[ "$addr" == */* ]]; then
    scope="${addr%%/*}"
    name="${addr#*/}"
  fi

  local self="${TMUX_PANE:-}"
  local all rows
  all="$(list_agents | awk -F'\t' -v n="$name" -v self="$self" '$5 == n && $3 != self')"

  if [[ -n "$scope" ]]; then
    rows="$(awk -F'\t' -v s="$scope" '{ nf = split($4, a, "/") } $1 == s || a[nf] == s' <<< "$all")"
  elif [[ -n "$self" ]]; then
    # 暗黙解決は session を跨がない: 同じ window → 同じ session の順
    local win ses
    win="$(tmux display-message -p -t "$self" '#{window_id}')"
    ses="$(tmux display-message -p -t "$self" '#{session_name}')"
    rows="$(awk -F'\t' -v w="$win" '$2 == w' <<< "$all")"
    [[ -n "$rows" ]] || rows="$(awk -F'\t' -v s="$ses" '$1 == s' <<< "$all")"
  else
    rows="$all"
  fi

  local count
  count="$(grep -c . <<< "$rows" || true)"
  if [[ "$count" -eq 1 ]]; then
    awk -F'\t' '{ print $3 }' <<< "$rows"
  elif [[ "$count" -eq 0 ]]; then
    {
      echo "agent-talk: 宛先 '$addr' がスコープ内に見つかりません。待受中:"
      list_agents | pretty
    } >&2
    return 1
  else
    {
      echo "agent-talk: 宛先 '$addr' の候補が複数あります。<scope>/<name> で指定してください:"
      pretty <<< "$rows"
    } >&2
    return 1
  fi
}

cmd_send() {
  local addr="${1:-}"
  [[ -n "$addr" ]] || die "usage: agent-talk send [scope/]<name> [message]"
  shift
  local name="${addr#*/}"

  local pane
  pane="$(cmd_resolve "$addr")"

  local body
  if [[ $# -gt 0 ]]; then
    body="$*"
  else
    body="$(cat)"
  fi
  [[ -n "$body" ]] || die "本文が空です"

  local from="human" from_session=""
  if [[ -n "${TMUX_PANE:-}" ]]; then
    from="$(tmux display-message -p -t "$TMUX_PANE" '#{@agent}' 2>/dev/null || true)"
    from_session="$(tmux display-message -p -t "$TMUX_PANE" '#{session_name}' 2>/dev/null || true)"
    [[ -n "$from" ]] || from="human"
  fi

  # 宛先の登録名。pane ID 指定なら登録名を引く。dispatch のロック内で
  # この名前と再照合し、resolve 後に宛先が入れ替わっていたら配達しない
  local expect="$name"
  [[ "$addr" =~ ^%[0-9]+$ ]] \
    && expect="$(list_agents | awk -F'\t' -v p="$pane" '$3 == p { print $5 }')"
  local fname
  fname="$(tr -cd 'A-Za-z0-9_-' <<< "$expect")"
  [[ -n "$fname" ]] || fname="agent"
  local from_fname
  from_fname="$(tr -cd 'A-Za-z0-9_-' <<< "$from")"
  [[ -n "$from_fname" ]] || from_fname="human"

  # 新規dir/fileは非公開で作る。既存のAGENT_TALK_DIRの権限は変更しない。
  # mktempにより、共有ディレクトリ指定時も衝突とsymlink差し替えを避ける。
  umask 077
  mkdir -p -m 700 -- "$MAILDIR"
  local file
  file="$(mktemp "$MAILDIR/$(date +%Y%m%d-%H%M%S)-${from_fname}-to-${fname}-XXXXXX.md")"

  local reply="不要 (人間からの依頼。結果は自分の画面に表示すれば読まれる)"
  if [[ "$from" != "human" && -n "${TMUX_PANE:-}" ]]; then
    reply="agent-talk send '${TMUX_PANE}' に返信本文を stdin で渡す (pane ID 指定は曖昧にならない)"
  fi

  local origin=""
  [[ -n "$from_session" ]] && origin=" (session: ${from_session}, pane: ${TMUX_PANE})"

  {
    echo "# agent-talk 依頼書"
    echo "- from: ${from}${origin}"
    echo "- to: ${addr}"
    echo "- reply: ${reply}"
    echo
    echo "$body"
  } > "$file"

  local bell="[agent-talk] ${from} から依頼が届きました。${file} を読んで対応してください。"

  # ボールを相手に渡したターンは完了の声を出さない (チェーン最後の者だけが喋る)。
  # 自ターン内で set し自ターン終了時に emit-turn-end.sh が消費する。
  # キュー退避でもボールは渡っているので同様に立てる
  if [[ "$from" != "human" && -n "${TMUX_PANE:-}" ]]; then
    tmux set-option -p -t "$TMUX_PANE" @agent_talk_sent 1 2>/dev/null || true
  fi

  local rc=0
  dispatch "$pane" "${TMUX_PANE:-human}" "$file" "$bell" "$expect" || rc=$?
  case "$rc" in
    0) echo "sent -> $pane ($addr): $file" ;;
    1) echo "queued (busy) -> $pane ($addr): $file" ;;
    2) die "宛先 $pane ($addr) は退出済みです。依頼書は $file に残っています" ;;
    *) die "キューへ書き込めず配達できません (依頼書は $file に残っています)" ;;
  esac
}

case "${1:-}" in
  register)   shift; cmd_register "$@" ;;
  unregister) shift; cmd_unregister "$@" ;;
  busy)       shift; cmd_busy "$@" ;;
  idle)       shift; cmd_idle "$@" ;;
  turn-end)   shift; cmd_turn_end "$@" ;;
  watch)      shift; cmd_watch "$@" ;;
  who)        shift; cmd_who "$@" ;;
  gc)         shift; cmd_gc "$@" ;;
  resolve)    shift; cmd_resolve "$@" ;;
  send)       shift; cmd_send "$@" ;;
  *)
    sed -n '4,31p' "$0" | sed 's/^# \{0,1\}//'
    exit 1
    ;;
esac

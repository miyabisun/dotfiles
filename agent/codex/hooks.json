{
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.dotfiles/agent/codex/hooks/notify-waiting.sh",
            "timeout": 10,
            "statusMessage": "確認待ちを通知"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.dotfiles/agent/codex/hooks/block-git-discard.sh",
            "timeout": 10,
            "statusMessage": "git 破棄コマンドチェック"
          }
        ]
      }
    ]
  }
}
